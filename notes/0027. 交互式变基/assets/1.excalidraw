    {
      "id": "ToF0iJA0cWAI6b3IFLL8e",
      "type": "text",
      "x": 221.11126744856847,
      "y": -348.8334346764241,
      "width": 1154.9996337890625,
      "height": 1225,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "cross-hatch",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aB",
